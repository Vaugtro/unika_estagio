{
  "name": "unika-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "playwright test --config=e2e/playwright.config.ts",
    "e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "e2e:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "e2e:report": "playwright show-report e2e/playwright-report",
    "generate:api": "openapi-generator-cli generate -i http://localhost:8080/v3/api-docs -g typescript-angular -t ./src/templates -o ./src/app/api --additional-properties=ngVersion=14.2.0,useHttpClient=true,supportsES6=true && node -e \"const m=require('mustache'),f=require('fs'),d=JSON.parse(f.readFileSync('src/templates/provide-api-data.json','utf8')),t=f.readFileSync('src/templates/provide-api.mustache','utf8'),p={licenseInfo:f.readFileSync('src/templates/partials/licenseInfo.mustache','utf8')};f.writeFileSync('src/app/api/provide-api.ts',m.render(t,d,p))\""
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/build-angular": "14.2.13",
    "@angular/animations": "^14.2.0",
    "@angular/cdk": "^14.2.7",
    "@angular/common": "^14.2.0",
    "@angular/compiler": "^14.2.0",
    "@angular/core": "^14.2.0",
    "@angular/forms": "^14.2.0",
    "@angular/material": "^14.2.7",
    "@angular/platform-browser": "^14.2.0",
    "@angular/platform-browser-dynamic": "^14.2.0",
    "@angular/router": "^14.2.0",
    "@tailwindcss/postcss": "^4.3.0",
    "lucide-angular": "1.0.0",
    "ngx-mask": "^14.3.3",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular/cli": "~14.2.13",
    "@angular/compiler-cli": "^14.2.0",
    "@openapitools/openapi-generator-cli": "^2.34.0",
    "@playwright/test": "^1.60.0",
    "@types/jasmine": "~4.0.0",
    "autoprefixer": "^10.5.0",
    "jasmine-core": "~4.3.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "mustache": "^4.2.0",
    "nx": "15.9.7",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~4.7.2"
  }
}
