        "google/gemini-3.1-flash-lite",
        "kilo/kilo-auto/free",
        "github-copilot/gpt-5-mini",
        "github-copilot/claude-haiku-4.5"
      ],
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "max",
      "temperature": 0.1,
      "tools": {
        "edit_file": true,
        "read_file": true,
        "skill": true,
        "web_search": true,
        "write_file": true
      }
    }
  },
  "background_task": {
    "modelConcurrency": {
      "deepseek/deepseek-chat": 5,
      "deepseek/deepseek-reasoner": 2,
      "deepseek/deepseek-v4-flash": 10,
      "deepseek/deepseek-v4-pro": 5,
      "github-copilot/claude-haiku-4.5": 5,
      "github-copilot/gpt-4.1": 3,
      "github-copilot/gpt-5-mini": 5,
      "google/antigravity-claude-opus-4-6-thinking": 1,
      "google/antigravity-claude-sonnet-4-6": 1,
      "google/antigravity-gemini-3-flash": 2,
      "google/antigravity-gemini-3-pro": 1,
      "google/antigravity-gemini-3.1-pro": 1,
      "google/gemma-4-26b-a4b-it": 3,
      "google/gemma-4-31b-it": 3,
      "google/gemini-2.0-flash": 10,
      "google/gemini-2.5-flash": 5,
      "google/gemini-2.5-flash-image": 3,
      "google/gemini-2.5-pro": 2,
      "google/gemini-3-flash-preview": 5,
      "google/gemini-3.1-flash-lite": 5,
      "google/gemini-3.1-flash-image-preview": 3,
      "google/gemini-3.1-pro-preview": 2,
      "google/gemini-3.5-flash": 5,
      "nvidia/gemma-3n-e2b-it": 10,
      "nvidia/llama-4-maverick-17b-128e-instruct": 3,
      "nvidia/minimaxai/minimax-m2.7": 3,
      "nvidia/qwen3-coder-480b-a35b-instruct": 3,
      "nvidia/stepfun-ai/step-3.5-flash": 5,
      "opencode-go/deepseek-v4-flash": 20,
      "opencode-go/deepseek-v4-pro": 5,
      "opencode-go/glm-5": 2,
      "opencode-go/glm-5.1": 2,
      "opencode-go/kimi-k2.6": 3,
      "opencode-go/minimax-m2.7": 2,
      "opencode-go/qwen3.6-plus": 5
    }
  },
  "categories": {
    "artistry": {
      "fallback_models": [
        "google/gemini-3.1-pro-preview",
        "github-copilot/gpt-4.1"
      ],
      "model": "google/gemini-2.5-pro"
    },
    "deep": {
      "fallback_models": [
        "nvidia/minimaxai/minimax-m2.7",
        "opencode-go/kimi-k2.6"
      ],
      "model": "google/gemini-2.5-pro"
    },
    "quick": {
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "google/gemini-2.0-flash",
        "github-copilot/claude-haiku-4.5"
      ],
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "max",
      "temperature": 0.1
    },
    "ultrabrain": {
      "fallback_models": [
        "google/gemini-2.5-pro",
        "github-copilot/gpt-4.1"
      ],
      "model": "google/antigravity-claude-opus-4-6-thinking"
    },
    "unspecified-high": {
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "nvidia/minimaxai/minimax-m2.7"
      ],
      "model": "opencode-go/deepseek-v4-pro"
    },
    "unspecified-low": {
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "google/gemini-3.1-flash-lite",
        "github-copilot/gpt-5-mini"
      ],
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "max",
      "temperature": 0.1
    },
    "visual-engineering": {
      "fallback_models": [
        "google/gemini-3.1-flash-image-preview",
        "github-copilot/gpt-4.1"
      ],
      "model": "google/gemini-2.5-flash-image"
    },
    "writing": {
      "fallback_models": [
        "google/gemini-2.0-flash",
        "github-copilot/gpt-5-mini"
      ],
      "model": "google/gemini-3.1-flash-lite"
    }
  },
  "experimental": {
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "detailed",
      "protected_tools": [
        "skill",
        "task"
      ],
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "purge_errors": {
          "enabled": true,
          "turns": 5
        },
        "supersede_writes": {
          "aggressive": false,
          "enabled": true
        }
      },
      "turn_protection": {
        "enabled": true,
        "turns": 3
      }
    }
  },
  "git_master": {
    "commit_footer": true,
    "git_env_prefix": "GIT_MASTER=1",
    "include_co_authored_by": true
  },
  "tmux": {
    "agent_pane_min_width": 40,
    "enabled": true,
    "isolation": "window",
    "layout": "main-vertical",
    "main_pane_min_width": 120,
    "main_pane_size": 60
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [429, 500, 502, 503, 504, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  }
}