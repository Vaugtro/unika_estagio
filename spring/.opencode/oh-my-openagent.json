        "google/gemini-2.5-pro",
        "github-copilot/gpt-4.1",
        "deepseek/deepseek-reasoner"
      ],
      "model": "google/antigravity-claude-sonnet-4-6",
      "tools": {
        "read_file": true,
        "search_files": true,
        "skill": true
